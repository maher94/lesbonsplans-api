# ============================================================
# Variables d'environnement — LeBonPlan API
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env !
# ============================================================

# Base de données (Neon.tech pour la prod)
DATABASE_URL=jdbc:postgresql://localhost:5432/lebonplan
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# JWT — générer une clé aléatoire solide en prod
# openssl rand -base64 64
JWT_SECRET=changez-moi-en-production-cle-secrete-minimum-256-bits

# Cloudinary (images)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — URLs du frontend autorisées
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Port (Railway/Render l'injectent automatiquement)
PORT=8080
